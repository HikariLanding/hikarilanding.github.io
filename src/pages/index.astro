---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { loadRepos } from '../lib/load-repos';
import { selectProjects } from '../lib/projects';

const projects = selectProjects(await loadRepos());

const description = 'An open-source home for small software — warm, simple, quietly useful.';
const year = new Date().getFullYear();

const principles = [
  {
    title: 'Small tools, done well',
    body: 'One job each, cared for past the point anyone would notice.',
  },
  {
    title: 'Simple over clever',
    body: "The obvious way, made pleasant. Cleverness ages badly; clarity doesn't.",
  },
  {
    title: 'Light, not noise',
    body: 'Software that illuminates, then gets out of the way.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HikariLanding</title>
    <meta name="description" content={description} />
    <meta property="og:title" content="HikariLanding" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      /* 防闪烁:首帧前应用已存的显式选择。逻辑同 src/lib/theme.ts 的 stored 分支——改动需同步 */
      try {
        var storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'light' || storedTheme === 'dark') {
          document.documentElement.setAttribute('data-theme', storedTheme);
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <ThemeToggle />
    <main>
      <section class="hero">
      <div class="glow-orb" aria-hidden="true"></div>
      <p class="wordmark">Hikari</p>
      <h1>Small ideas <em>land</em> and become real.</h1>
      <p class="sub">{description}</p>
    </section>

    <section class="principles" aria-label="Principles">
      {
        principles.map((principle, i) => (
          <div class="principle">
            <span class="num" aria-hidden="true">
              {i + 1}
            </span>
            <div>
              <h2>{principle.title}</h2>
              <p>{principle.body}</p>
            </div>
          </div>
        ))
      }
    </section>

    <section class="projects-section" aria-labelledby="projects-heading">
      <h2 id="projects-heading" class="projects-heading">Projects</h2>
      {
        projects.length === 0 ? (
          <p class="empty">something new is being built</p>
        ) : (
          <ul class="projects">
            {projects.map((project) => (
              <li>
                <a class="card" href={project.url}>
                  <span class="card-name">{project.name}</span>
                  {project.description && <span class="card-desc">{project.description}</span>}
                  {project.language && <span class="card-lang">{project.language}</span>}
                </a>
              </li>
            ))}
          </ul>
        )
      }
      </section>
    </main>

    <footer>
      <p>© {year} HikariLanding</p>
      <a href="https://github.com/HikariLanding">GitHub</a>
    </footer>
  </body>
</html>

<style>
  /* ---- 主题同拍（票⑦/ADR 0003） ----
     随主题变化的颜色类属性(color/background-color/border-color)统一 --dur-ui 一拍;
     光晕与强调词微光(--dur-glow)是唯一例外拍。
     同一元素框禁止双拍:兼任 hover 反馈的颜色属性(卡片、页脚链接、开关)同样归 --dur-ui——
     150/200 之差不可辨,撕裂可辨。
     入列规则:显式自设颜色/背景/边框的元素必须在此列(或在自带 transition 清单里并入同拍);
     继承色元素(h1、h2 等)随 body 的过渡自然同拍,不必入列 ---- */

  .wordmark,
  .sub,
  .num,
  .principle,
  .principle p,
  .projects-heading,
  .empty,
  .card-name,
  .card-desc,
  .card-lang,
  footer {
    transition:
      color var(--dur-ui) ease,
      background-color var(--dur-ui) ease,
      border-color var(--dur-ui) ease;
  }

  /* ---- Hero（原型变体 B — Lantern） ---- */

  .hero {
    min-height: 82vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 62rem;
    margin: 0 auto;
    padding: 4rem 2.5rem;
    position: relative;
  }

  .glow-orb {
    position: absolute;
    top: 18%;
    left: -6%;
    width: 34rem;
    height: 22rem;
    max-width: 100vw;
    /* 渐变色为常量(=暗色 --glow 终值),不吃 var(票⑩改判):主题切换只走 opacity 单通道——
       静态模糊层缓存为合成器纹理,切换零逐帧 paint;颜色不再翻转,暗→亮「一帧消失」构造性根除。
       亮色下 --glow-strength=0,层不可见 */
    background: radial-gradient(closest-side, rgba(245 184 76 / 0.16), transparent);
    filter: blur(64px);
    opacity: var(--glow-strength);
    pointer-events: none;
    /* 光晕本体静态(ADR 0002);此过渡只服务主题切换——光比纸慢半拍,--dur-glow 例外拍(ADR 0003) */
    transition: opacity var(--dur-glow) ease;
  }

  .wordmark {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 3rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-weight: 500;
    /* 光学定稿(票⑨,区间内截图对比):字距 -0.02~-0.022em 两端在 83px 下不可辨
       (差 0.17px/字),取保守端防 44.8px 斜体 land 粘连;行高取紧端 1.1——
       两行标题更成块,1.12 的余量在两三行内无收益。改值须重走截图对比 */
    letter-spacing: -0.02em;
    line-height: 1.1;
    /* balance 修中等宽度(~500px)的 4+2 失衡断行:land 收在首行尾,两行 3+3 */
    text-wrap: balance;
    max-width: 18ch;
    margin: 0;
    position: relative;
  }

  h1 em {
    font-style: italic;
    color: var(--accent);
    /* 强调词微光只在主题给出 glow 时出现(暗色)——ADR 0002。
       半径常量 24px,可见性全交 --glow alpha(亮色 transparent 即隐形)——票⑩:
       半径吃 --glow-strength 时,RM 下 strength 离散翻转令微光一帧瞬灭 */
    text-shadow: 0 0 24px var(--glow);
    /* 微光与光晕同拍(--dur-glow 例外拍);color 归主题一拍——票⑦。
       RM 下 text-shadow 不在白名单,渐隐靠 --glow 自身插值(注册见 global.css),
       槽位循环取 0.2s ≠ 家族 0.3s 拍——已判不可辨,豁免(票⑩) */
    transition:
      color var(--dur-ui) ease,
      text-shadow var(--dur-glow) ease;
  }

  .sub {
    margin: 2rem 0 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 46ch;
    text-wrap: pretty;
  }

  /* ---- 三原则 ---- */

  .principles {
    max-width: 62rem;
    margin: 0 auto;
    padding: 5rem 2.5rem;
  }

  .principle {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    padding: 3rem 0;
    border-top: 1px solid var(--border);
    align-items: baseline;
  }

  .num {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    color: var(--accent);
    opacity: 0.85;
    font-variant-numeric: tabular-nums;
  }

  .principle h2 {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: -0.012em; /* 票⑨定稿:1.7rem 档的光学收紧——字越大越收紧(h1 -0.02em) */
    margin: 0 0 0.6rem;
  }

  .principle p {
    color: var(--text-secondary);
    font-size: 0.98rem;
    max-width: 52ch;
    margin: 0;
    text-wrap: pretty;
  }

  /* ---- 项目区（票 #4 定稿的卡片） ---- */

  .projects-section {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0 2.5rem 9rem;
  }

  .projects-heading {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }

  .projects {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    max-width: 46rem;
  }

  .card {
    position: relative;
    display: grid;
    gap: 0.375rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    /* 颜色类归主题同拍 --dur-ui,且排在 transform 之前(与开关同一纪律):
       RM 白名单按 transition-property 顺序循环取 duration,颜色类须落进 --dur-ui 槽位,
       同框 border/background 在 RM 下才不撕裂——票⑦。
       transform 槽位是按压回弹拍(--dur-ui,ADR 0003「快下慢回」):回弹与 hover 抬升
       共用本基态声明,抬升遂从 --dur-fast 并入同拍——150/200 之差不可辨——票⑧ */
    transition:
      color var(--dur-ui) ease,
      border-color var(--dur-ui) ease,
      background-color var(--dur-ui) ease,
      transform var(--dur-ui) var(--ease-out);
  }

  /* 昼影(票⑧/ADR 0003「深度对称」):伪元素预画 box-shadow,浮现只过渡 opacity——
     不直接过渡 box-shadow(每帧重绘)。--shadow 暗色为 transparent,整值失效回落
     none:昼有影,夜的抬升层次由 border/surface 承担 */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: var(--shadow);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-fast) ease;
  }

  /* 卡片聚焦走全站统一焦点环(global.css,票⑨)——border 变色还给 hover */

  /* 按压节拍(ADR 0003):快下慢回——按下 --dur-press,回弹随基态走 --dur-ui。
     只覆写 transition-duration 并逐槽对齐基态列表(颜色×3 + transform),
     不动 transition-property:整表简写会重排 RM 白名单的槽位循环,
     颜色类被拖离 --dur-ui 同拍(anti-tearing/slot-alignment 测试执法) */
  .card:active {
    transform: scale(0.99);
    transition-duration: var(--dur-ui), var(--dur-ui), var(--dur-ui), var(--dur-press);
  }

  /* hover 专属效果(位移、变色、昼影)一律进 (hover:hover):触屏 tap 不残留 sticky 态。
     :active 在此写完整 transform 合成——部分覆写会让按下瞬间先坠 2px 再收缩
     (transform 通道相撞,ADR 0003 背景③);触屏维持上面的纯 scale */
  @media (hover: hover) and (pointer: fine) {
    .card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }

    .card:hover::after {
      opacity: 1;
    }

    .card:active {
      transform: translateY(-2px) scale(0.99);
    }
  }

  .card-name {
    color: var(--text);
    font-weight: 600;
  }

  .card-desc {
    color: var(--text-secondary);
    text-wrap: pretty;
  }

  .card-lang {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  /* ---- Footer ---- */

  footer {
    max-width: 62rem;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 3.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  footer p {
    margin: 0;
  }

  footer a {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    /* 颜色类归主题同拍 --dur-ui,hover 反馈同值——票⑦ */
    transition:
      color var(--dur-ui) ease,
      border-color var(--dur-ui) ease;
  }

  /* hover 变色入守卫(票⑨,随「变色还给 hover」一并收进):触屏 tap 无 sticky;
     键盘聚焦走全站焦点环(global.css) */
  @media (hover: hover) and (pointer: fine) {
    footer a:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
  }

  /* ---- 入场动效（票 #6 定稿）:仅 Hero 首屏,轻 fade-up,一次性;
     glow-orb 不参与(ADR 0002 静态条款)。
     600ms 与降级 300ms 是一次性 keyframes 值,定稿不入 token——ADR 0003 ---- */

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .wordmark,
  h1,
  .sub {
    animation: fade-up 600ms var(--ease-out) backwards;
  }

  h1 {
    animation-delay: 80ms;
  }

  .sub {
    animation-delay: 160ms;
  }

  /* 分级 reduced-motion 的唯一 keyframes 例外(ADR 0003):
     入场降级为纯 opacity 300ms,无 translateY。
     !important + 作用域特异性压过全局 animation: none 灭杀;
     shorthand 顺带清零 stagger 延迟——降级态三行同拍一次柔现,是有意为之 */

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wordmark,
    h1,
    .sub {
      animation: fade-in 300ms ease backwards !important;
    }

    /* 票⑧验收「RM 下无位移/抬升」:⑥ 的白名单只禁 transform 过渡,不禁状态位移,
       离散跳位对 RM 用户是无收益的闪变——整体置 none(同 hero 入场去位移的先例)。
       hover 反馈仍有 border 变色与昼影浮现(皆在白名单内)承担 */
    .card:hover,
    .card:active {
      transform: none;
    }
  }

  /* ---- 移动端 ---- */

  @media (max-width: 720px) {
    .hero,
    .principles,
    .projects-section,
    footer {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .principle {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
