---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { loadRepos } from '../lib/load-repos';
import { selectProjects } from '../lib/projects';

const projects = selectProjects(await loadRepos());

const description = 'An open-source home for small software — warm, simple, quietly useful.';
const year = new Date().getFullYear();

const principles = [
  {
    title: 'Small tools, done well',
    body: 'One job each, cared for past the point anyone would notice.',
  },
  {
    title: 'Simple over clever',
    body: "The obvious way, made pleasant. Cleverness ages badly; clarity doesn't.",
  },
  {
    title: 'Light, not noise',
    body: 'Software that illuminates, then gets out of the way.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HikariLanding</title>
    <meta name="description" content={description} />
    <meta property="og:title" content="HikariLanding" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      /* 防闪烁:首帧前应用已存的显式选择。逻辑同 src/lib/theme.ts 的 stored 分支——改动需同步 */
      try {
        var storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'light' || storedTheme === 'dark') {
          document.documentElement.setAttribute('data-theme', storedTheme);
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <ThemeToggle />
    <main>
      <section class="hero">
      <div class="glow-orb" aria-hidden="true"></div>
      <p class="wordmark">Hikari</p>
      <h1>Small ideas <em>land</em> and become real.</h1>
      <p class="sub">{description}</p>
    </section>

    <section class="principles" aria-label="Principles">
      {
        principles.map((principle, i) => (
          <div class="principle">
            <span class="num" aria-hidden="true">
              {i + 1}
            </span>
            <div>
              <h2>{principle.title}</h2>
              <p>{principle.body}</p>
            </div>
          </div>
        ))
      }
    </section>

    <section class="projects-section" aria-labelledby="projects-heading">
      <h2 id="projects-heading" class="projects-heading">Projects</h2>
      {
        projects.length === 0 ? (
          <p class="empty">something new is being built</p>
        ) : (
          <ul class="projects">
            {projects.map((project) => (
              <li>
                <a class="card" href={project.url}>
                  <span class="card-name">{project.name}</span>
                  {project.description && <span class="card-desc">{project.description}</span>}
                  {project.language && <span class="card-lang">{project.language}</span>}
                </a>
              </li>
            ))}
          </ul>
        )
      }
      </section>
    </main>

    <footer>
      <p>© {year} HikariLanding</p>
      <a href="https://github.com/HikariLanding">GitHub</a>
    </footer>
  </body>
</html>

<style>
  /* ---- Hero（原型变体 B — Lantern） ---- */

  .hero {
    min-height: 82vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 62rem;
    margin: 0 auto;
    padding: 4rem 2.5rem;
    position: relative;
  }

  .glow-orb {
    position: absolute;
    top: 18%;
    left: -6%;
    width: 34rem;
    height: 22rem;
    max-width: 100vw;
    background: radial-gradient(closest-side, var(--glow), transparent);
    filter: blur(64px);
    opacity: var(--glow-strength);
    pointer-events: none;
    /* 光晕本体静态(ADR 0002);此过渡只服务主题切换 */
    transition: opacity 300ms ease;
  }

  .wordmark {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 3rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.8rem, 7vw, 5.2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.15;
    max-width: 18ch;
    margin: 0;
    position: relative;
  }

  h1 em {
    font-style: italic;
    color: var(--accent);
    /* 强调词微光只在主题给出 glow 时出现（暗色）——ADR 0002 */
    text-shadow: 0 0 calc(var(--glow-strength) * 24px) var(--glow);
  }

  .sub {
    margin: 2rem 0 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 46ch;
  }

  /* ---- 三原则 ---- */

  .principles {
    max-width: 62rem;
    margin: 0 auto;
    padding: 5rem 2.5rem;
  }

  .principle {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    padding: 3rem 0;
    border-top: 1px solid var(--border);
    align-items: baseline;
  }

  .num {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    color: var(--accent);
    opacity: 0.85;
    font-variant-numeric: tabular-nums;
  }

  .principle h2 {
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 0.6rem;
  }

  .principle p {
    color: var(--text-secondary);
    font-size: 0.98rem;
    max-width: 52ch;
    margin: 0;
  }

  /* ---- 项目区（票 #4 定稿的卡片） ---- */

  .projects-section {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0 2.5rem 9rem;
  }

  .projects-heading {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }

  .projects {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    max-width: 46rem;
  }

  .card {
    display: grid;
    gap: 0.375rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    transition:
      border-color 150ms ease,
      transform 160ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card:hover,
  .card:focus-visible {
    border-color: var(--accent);
  }

  /* 悬停位移只给真指针设备;按压反馈触屏同样受益 */
  @media (hover: hover) and (pointer: fine) {
    .card:hover {
      transform: translateY(-2px);
    }
  }

  .card:active {
    transform: scale(0.99);
  }

  .card-name {
    color: var(--text);
    font-weight: 600;
  }

  .card-desc {
    color: var(--text-secondary);
  }

  .card-lang {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  /* ---- Footer ---- */

  footer {
    max-width: 62rem;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 3.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  footer p {
    margin: 0;
  }

  footer a {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }

  footer a:hover,
  footer a:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ---- 入场动效（票 #6 定稿）:仅 Hero 首屏,轻 fade-up,一次性;
     glow-orb 不参与(ADR 0002 静态条款);reduced-motion 由全局规则禁用 ---- */

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .wordmark,
  h1,
  .sub {
    animation: fade-up 600ms cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }

  h1 {
    animation-delay: 80ms;
  }

  .sub {
    animation-delay: 160ms;
  }

  /* ---- 移动端 ---- */

  @media (max-width: 720px) {
    .hero,
    .principles,
    .projects-section,
    footer {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .principle {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
