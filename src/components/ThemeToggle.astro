<button class="theme-toggle" aria-label="Toggle color theme">
  <svg
    class="icon icon-sun"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
    ></path>
  </svg>
  <svg
    class="icon icon-moon"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<script>
  import { resolveTheme, type Theme } from '../lib/theme';

  const root = document.documentElement;
  const button = document.querySelector<HTMLButtonElement>('.theme-toggle');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');

  const systemTheme = (): Theme => (prefersDark.matches ? 'dark' : 'light');
  /* 「当前主题」以 DOM 为准——localStorage 可能不可用(隐私模式)或已被其它标签页改写 */
  const currentTheme = (): Theme => resolveTheme(root.getAttribute('data-theme'), prefersDark.matches);

  button?.addEventListener('click', () => {
    const next = currentTheme() === 'dark' ? 'light' : 'dark';
    if (next === systemTheme()) {
      /* 切回系统侧 = 回到「跟随系统」:清除显式选择,OS 换主题时继续跟随 */
      root.removeAttribute('data-theme');
      try {
        localStorage.removeItem('theme');
      } catch {
        /* 存储不可用只影响持久化,本页已生效 */
      }
    } else {
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* 同上 */
      }
    }
  });

  /* 多标签页同步:别的标签页改了选择,本页跟着走 */
  window.addEventListener('storage', (event) => {
    if (event.key !== 'theme') return;
    if (event.newValue === 'light' || event.newValue === 'dark') {
      root.setAttribute('data-theme', event.newValue);
    } else {
      root.removeAttribute('data-theme');
    }
  });
</script>

<style>
  .theme-toggle {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 10;
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    background: var(--surface);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    /* 颜色三属性主题同拍 --dur-ui,撕裂在此终结(票⑦/ADR 0003);transform 属交互节拍。
       颜色类列首:RM 白名单按序循环取 duration,须让颜色类落进 --dur-ui 槽位 */
    transition:
      color var(--dur-ui) ease,
      border-color var(--dur-ui) ease,
      background-color var(--dur-ui) ease,
      transform var(--dur-fast) ease;
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    border-color: var(--accent);
    color: var(--text);
  }

  .theme-toggle:active {
    transform: scale(0.92);
  }

  .icon {
    grid-area: 1 / 1;
    width: 1.125rem;
    height: 1.125rem;
    transition:
      opacity var(--dur-ui) ease,
      transform var(--dur-ui) ease;
  }

  /* 图标可见性吃 --glow-strength(暗色=1 → 太阳,亮色=0 → 月亮),
     与光晕同一手法:零主题条件分支 —— docs/adr/0002 */
  .icon-sun {
    opacity: var(--glow-strength);
    transform: rotate(calc((1 - var(--glow-strength)) * 90deg));
  }

  .icon-moon {
    opacity: calc(1 - var(--glow-strength));
    transform: rotate(calc(var(--glow-strength) * -90deg));
  }
</style>
