<button class="theme-toggle" aria-label="Toggle color theme">
  <svg
    class="icon icon-sun"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
    ></path>
  </svg>
  <svg
    class="icon icon-moon"
    aria-hidden="true"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<script>
  import { resolveTheme, type Theme } from '../lib/theme';

  const root = document.documentElement;
  const button = document.querySelector<HTMLButtonElement>('.theme-toggle');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');

  const systemTheme = (): Theme => (prefersDark.matches ? 'dark' : 'light');
  /* 「当前主题」以 DOM 为准——localStorage 可能不可用(隐私模式)或已被其它标签页改写 */
  const currentTheme = (): Theme => resolveTheme(root.getAttribute('data-theme'), prefersDark.matches);

  button?.addEventListener('click', () => {
    const next = currentTheme() === 'dark' ? 'light' : 'dark';
    if (next === systemTheme()) {
      /* 切回系统侧 = 回到「跟随系统」:清除显式选择,OS 换主题时继续跟随 */
      root.removeAttribute('data-theme');
      try {
        localStorage.removeItem('theme');
      } catch {
        /* 存储不可用只影响持久化,本页已生效 */
      }
    } else {
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* 同上 */
      }
    }
  });

  /* 多标签页同步:别的标签页改了选择,本页跟着走 */
  window.addEventListener('storage', (event) => {
    if (event.key !== 'theme') return;
    if (event.newValue === 'light' || event.newValue === 'dark') {
      root.setAttribute('data-theme', event.newValue);
    } else {
      root.removeAttribute('data-theme');
    }
  });
</script>

<style>
  .theme-toggle {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 10;
    width: 2.75rem;
    height: 2.75rem;
    display: grid;
    place-items: center;
    background: var(--surface);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    /* 颜色三属性主题同拍 --dur-ui,撕裂在此终结(票⑦/ADR 0003)。
       颜色类列首:RM 白名单按序循环取 duration,须让颜色类落进 --dur-ui 槽位。
       transform 槽位是按压回弹拍(--dur-ui/--ease-out,ADR 0003「快下慢回」),照 .card 先例——票⑩ */
    transition:
      color var(--dur-ui) ease,
      border-color var(--dur-ui) ease,
      background-color var(--dur-ui) ease,
      transform var(--dur-ui) var(--ease-out);
  }

  /* hover 变色入守卫(票⑨):触屏 tap 无 sticky;键盘聚焦走全站焦点环(global.css) */
  @media (hover: hover) and (pointer: fine) {
    .theme-toggle:hover {
      border-color: var(--accent);
      color: var(--text);
    }
  }

  /* 按压节拍(ADR 0003,票⑩补作业):快下慢回——按下 --dur-press,回弹随基态走 --dur-ui。
     只覆写 transition-duration 并逐槽对齐基态列表(颜色×3 + transform),照 .card 先例:
     整表简写会重排 RM 白名单的槽位循环,颜色类被拖离 --dur-ui 同拍。
     深度 0.96:票⑩仲裁区间 0.95–0.97 内截图对比定稿(3x 采样)——0.97 与静止态
     几乎不可辨,0.95/0.96 差半像素,取中值;旧值 0.92 在 44px 圆钮上明显「按瘪」,
     与卡片 0.99 的克制人格失调 */
  .theme-toggle:active {
    transform: scale(0.96);
    transition-duration: var(--dur-ui), var(--dur-ui), var(--dur-ui), var(--dur-press);
  }

  .icon {
    grid-area: 1 / 1;
    width: 1.125rem;
    height: 1.125rem;
    /* 旋转曲线归 --ease-out(票⑩):与全站位移/回弹同一条曲线,90° 旋转尾段柔收 */
    transition:
      opacity var(--dur-ui) ease,
      transform var(--dur-ui) var(--ease-out);
  }

  /* 图标可见性吃 --glow-strength(暗色=1 → 太阳,亮色=0 → 月亮),
     与光晕同一手法:零主题条件分支 —— docs/adr/0002 */
  .icon-sun {
    opacity: var(--glow-strength);
    transform: rotate(calc((1 - var(--glow-strength)) * 90deg));
  }

  .icon-moon {
    opacity: calc(1 - var(--glow-strength));
    transform: rotate(calc(var(--glow-strength) * -90deg));
  }

  /* RM 下交互位移/形变整体不作用(ADR 0003 票⑧补充条款,票⑩把执法面从卡片扩展到开关):
     ⑥ 的白名单只禁 transform 过渡不禁状态位移,按压缩放与日/月旋转在 RM 下都成离散跳位——
     置 none 后可见图标不受影响(可见态旋转恒 0°),切换叙事由 opacity 渐变(白名单内)独任 */
  @media (prefers-reduced-motion: reduce) {
    .theme-toggle:active,
    .icon {
      transform: none;
    }
  }
</style>
